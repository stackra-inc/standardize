{
  "name": "@stackra/standardize",
  "version": "1.0.0",
  "description": "CLI tool to audit and standardize all @stackra/* packages — configs, scripts, hooks, steering, CI",
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://github.com/stackra-inc"
  },
  "type": "module",
  "bin": {
    "stackra-std": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "steering",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "audit": "tsx src/index.ts audit",
    "verify": "tsx src/index.ts verify",
    "install-all": "tsx src/index.ts install",
    "deps": "tsx src/index.ts deps",
    "help": "tsx src/index.ts help",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "keywords": [
    "stackra",
    "standardize",
    "cli",
    "tooling",
    "monorepo"
  ],
  "dependencies": {
    "tsup": "^8.5.1"
  },
  "devDependencies": {
    "@stackra/tsup-config": "^1.0.6",
    "@stackra/typescript-config": "^1.0.5",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "@types/node": "^22.15.0"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stackra-inc/standardize.git"
  },
  "homepage": "https://github.com/stackra-inc/standardize#readme",
  "bugs": {
    "url": "https://github.com/stackra-inc/standardize/issues"
  }
}
